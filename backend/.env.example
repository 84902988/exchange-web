# Backend sanitized environment example.
# Copy to backend/.env and fill secrets outside version control.

APP_ENV=production
APP_NAME=exchange-api

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=exchange
DB_PASSWORD=change-me
DB_NAME=exchange
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
ENABLE_DB_AUTO_CREATE_ALL=false

# Security / JWT
JWT_SECRET=change-me-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
SECURITY_PEPPER=change-me-long-random-string

# Cookie / Auth
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_PATH=/
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACCESS_TOKEN_MAX_AGE=900
REFRESH_TOKEN_MAX_AGE=2592000
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
GEO_ACCESS_ENABLED=false
GEO_ACCESS_MONITOR_MODE=true
GEOIP_DB_PATH=
GEO_ACCESS_TRUST_CF_HEADER=true

# DB lifecycle cleanup. Safe defaults: scheduler disabled, worker dry-run.
DB_LIFECYCLE_CLEANUP_ENABLED=false
DB_LIFECYCLE_CLEANUP_DRY_RUN=true
DB_LIFECYCLE_CLEANUP_ALLOW_EXECUTE=false
DB_LIFECYCLE_CLEANUP_EXECUTE_CONFIRM=
DB_LIFECYCLE_CLEANUP_RETENTION_DAYS=90
DB_LIFECYCLE_CLEANUP_ENQUEUE_INTERVAL_SECONDS=86400

# Redis / RQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=exchange
# REDIS_URL=redis://127.0.0.1:6379/0

# Email
ALIYUN_ACCESS_KEY_ID=change-me
ALIYUN_ACCESS_KEY_SECRET=change-me
ALIYUN_DM_REGION=ap-southeast-1
ALIYUN_DM_ACCOUNT_NAME=no-reply@example.com
ALIYUN_DM_FROM_ALIAS=Royal Exchange

# Moralis / deposit webhook
MORALIS_API_KEY=change-me
MORALIS_WEBHOOK_SECRET=change-me
MORALIS_STREAMS_ENABLED=false
MORALIS_STREAM_ID_ETH=
MORALIS_STREAM_ID_BSC=
MORALIS_STREAM_ID_POLYGON=
MORALIS_STREAM_ID_ARBITRUM=

# Market data
ITICK_API_TOKEN=change-me
ITICK_API_BASE_URL=https://api.itick.org
ITICK_INDICES_API_BASE_URL=
ITICK_FOREX_API_BASE_URL=
ITICK_FUTURE_API_BASE_URL=
ITICK_FUND_API_BASE_URL=
ITICK_CRYPTO_API_BASE_URL=
ITICK_QUOTE_DEPTH_CACHE_TTL_SECONDS=2
ITICK_QUOTE_DEPTH_STALE_TTL_SECONDS=20
ITICK_QUOTE_DEPTH_COOLDOWN_SECONDS=10
BINANCE_USDM_BASE_URL=https://fapi.binance.com
BINANCE_USDM_FALLBACK_BASE_URLS=
BINANCE_USDM_USE_ENV_PROXY=false
PROXY_ENABLED=false
PROXY_URL=

# Contract CFD
CONTRACT_CFD_ENABLED=false
CONTRACT_CFD_DEFAULT_MARGIN_ASSET=USDT
CONTRACT_CFD_MAX_LEVERAGE=200
CONTRACT_CFD_USE_LAST_VALID_PRICE=true

# Independent daemon ownership.
# Keep disabled in generic web/API processes unless this instance owns the job.
ENABLE_WITHDRAW_WATCHER=0
WITHDRAW_WATCH_INTERVAL=20
WITHDRAW_WATCH_MAX_BATCH=50
WITHDRAW_WATCH_CONFIRMATIONS=1
ENABLE_CONTRACT_TP_SL_JOB=0
CONTRACT_TP_SL_INTERVAL=2
ENABLE_CONTRACT_LIMIT_ORDER_JOB=0
CONTRACT_LIMIT_ORDER_INTERVAL=2
ENABLE_DIVIDEND_JOB=0
ENABLE_BD_COMMISSION_JOB=0
ENABLE_STOCK_TOKEN_RELEASE_JOB=0
ENABLE_RWA_REFERENCE_JOB=0
ENABLE_STOCK_DEALER_TRADE_JOB=0
STOCK_DEALER_TRADE_INTERVAL_SECONDS=3

# Wallet / chain config
MNEMONIC=
WALLET_AES_KEY=
HOT_WALLET_PRIVATE_KEY=
PLATFORM_HOT_WALLET=
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_RPC_URLS=https://polygon.drpc.org,https://rpc.ankr.com/polygon,https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.bnbchain.org
BSC_RPC_URLS=https://bsc-dataseed.binance.org,https://bsc-dataseed1.binance.org,https://bsc.publicnode.com
RPC_ETH=
RPC_BSC=
RPC_POLYGON=
RPC_ARBITRUM=
PRICE_BSC=1
PRICE_POLYGON=1
PRICE_ARBITRUM=1

# Withdraw
WITHDRAW_MIN_FEE=0.005
WITHDRAW_FEE_BUFFER=1.3

# Collection real-send infrastructure master switch. Defaults are safe.
# Business rules come from backend chain / asset-chain config.
COLLECTION_REAL_SEND_MASTER_SWITCH=false
# Legacy fallback only for old deployments before DB-backed collection limits.
# COLLECTION_ENABLE_REAL_SEND=false
# COLLECTION_ALLOWED_CHAINS=
# COLLECTION_ALLOWED_TARGET_ADDRESSES=
# COLLECTION_MAX_SINGLE_COLLECT_USDT=
# COLLECTION_DAILY_COLLECT_USDT_LIMIT=
# COLLECTION_MAX_SINGLE_GAS_NATIVE_ETH=
# COLLECTION_DAILY_GAS_NATIVE_LIMIT_ETH=
# COLLECTION_MAX_SINGLE_GAS_NATIVE_BSC=
# COLLECTION_DAILY_GAS_NATIVE_LIMIT_BSC=
# COLLECTION_MAX_SINGLE_GAS_NATIVE_POLYGON=
# COLLECTION_DAILY_GAS_NATIVE_LIMIT_POLYGON=
# COLLECTION_MAX_SINGLE_GAS_NATIVE_ARBITRUM=
# COLLECTION_DAILY_GAS_NATIVE_LIMIT_ARBITRUM=
COLLECTION_GAS_HOT_PRIVATE_KEY=
