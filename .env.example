# Root environment example for local orchestration.
# Backend reads backend/.env directly; web reads web/.env.local.

APP_ENV=production

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
GEO_ACCESS_ENABLED=false
GEO_ACCESS_MONITOR_MODE=true
GEOIP_DB_PATH=
GEO_ACCESS_TRUST_CF_HEADER=true
DB_LIFECYCLE_CLEANUP_ENABLED=false
DB_LIFECYCLE_CLEANUP_DRY_RUN=true
DB_LIFECYCLE_CLEANUP_ALLOW_EXECUTE=false
DB_LIFECYCLE_CLEANUP_EXECUTE_CONFIRM=
DB_LIFECYCLE_CLEANUP_RETENTION_DAYS=90
DB_LIFECYCLE_CLEANUP_ENQUEUE_INTERVAL_SECONDS=86400

# Frontend
WEB_HOST=127.0.0.1
WEB_PORT=3000
