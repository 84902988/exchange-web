# Web sanitized environment example.
# Copy to web/.env.local for local runs.

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_NAME=Royal Exchange
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_VERSION=local
GEO_ACCESS_ENABLED=false
GEO_ACCESS_RESTRICTED_COUNTRIES=
GEO_ACCESS_TRUST_CF_HEADER=true
WEB_GEO_ACCESS_TEST_LOCAL=false
