[Unit]
Description=Exchange dealer order loop
After=network-online.target redis.service exchange-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/exchange-web/backend
EnvironmentFile=/opt/exchange-web/backend/.env
User=exchange
Group=exchange
ExecStart=/opt/exchange-web/.venv/bin/python scripts/start_dealer_loop.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
