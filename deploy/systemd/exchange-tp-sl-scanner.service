[Unit]
Description=Exchange contract TP/SL scanner
After=network-online.target redis.service exchange-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/exchange-web/backend
EnvironmentFile=/opt/exchange-web/backend/.env
User=exchange
Group=exchange
ExecStart=/opt/exchange-web/.venv/bin/python scripts/start_tp_sl_scanner.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
