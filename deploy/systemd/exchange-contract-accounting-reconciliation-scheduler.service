[Unit]
Description=Exchange contract accounting reconciliation scheduler
After=network-online.target redis.service
Wants=network-online.target redis.service
PartOf=exchange-backend.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/opt/exchange-web/backend
EnvironmentFile=/opt/exchange-web/backend/.env
Environment=PYTHONUNBUFFERED=1
User=exchange
Group=exchange
ExecStart=/opt/exchange-web/.venv/bin/python scripts/start_contract_accounting_reconciliation_scheduler.py
Restart=always
RestartSec=5
TimeoutStopSec=30
KillSignal=SIGTERM
KillMode=mixed
StandardOutput=journal
StandardError=journal
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
UMask=0027

[Install]
WantedBy=multi-user.target
